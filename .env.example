# ── Google Sheet ──────────────────────────────────────────────────────────────
SHEET_ID=your_google_sheet_id_here

# Tab names (change only if you rename them in the sheet)
TAB_STORIES=1_Stories
TAB_VIDEOS=2_Videos
TAB_PROCESS=3_Process
TAB_YOUTUBE=4_YouTube
TAB_DASHBOARD=Dashboard
TAB_CREDITS=Credits

# ── Google Drive ──────────────────────────────────────────────────────────────
DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── MagicLight credentials (fallback if accounts.txt is empty) ────────────────
ML_EMAIL=your@email.com
ML_PASSWORD=yourpassword

# ── Pipeline timing (seconds) ─────────────────────────────────────────────────
STEP1_WAIT=60
STEP2_WAIT=30
STEP3_WAIT=180
STEP4_RENDER_TIMEOUT=1200

# ── Assets ────────────────────────────────────────────────────────────────────
LOGO_PATH=assets/logo.png
ENDSCREEN_VIDEO=assets/endscreen.mp4

# ── FFmpeg settings ───────────────────────────────────────────────────────────
TRIM_SECONDS=4
LOGO_X=7
LOGO_Y=5
LOGO_WIDTH=300
LOGO_OPACITY=1.0
ENDSCREEN_ENABLED=true

# ── Feature flags ─────────────────────────────────────────────────────────────
UPLOAD_TO_DRIVE=false
DEBUG=0

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: This file is for LOCAL development only.
# On GitHub Actions, set everything as Secrets + Variables — NOT .env
# See README.md → "GitHub Actions Setup" for the full table.
# ─────────────────────────────────────────────────────────────────────────────
