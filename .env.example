# MagicLight Auto — Environment Configuration

# ── Google Sheet ───────────────────────────────────────────────────────────
SHEET_ID=your_google_sheet_id_here
SHEET_NAME=Database
CREDS_JSON=credentials.json

# ── Google Drive ───────────────────────────────────────────────────────────
DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── MagicLight Account (fallback if accounts.txt is empty) ────────────────
EMAIL=your@email.com
PASSWORD=yourpassword

# ── Pipeline Timing (seconds) ─────────────────────────────────────────────
STEP1_WAIT=60
STEP2_WAIT=30
STEP3_WAIT=180
STEP4_RENDER_TIMEOUT=1200

# ── Output & Assets ────────────────────────────────────────────────────────
MAGICLIGHT_OUTPUT=output
LOGO_PATH=assets/logo.png
ENDSCREEN_VIDEO=assets/endscreen.mp4

# ── FFmpeg / Branding ──────────────────────────────────────────────────────
TRIM_SECONDS=4
LOGO_X=7
LOGO_Y=5
LOGO_WIDTH=300
LOGO_OPACITY=1.0
ENDSCREEN_ENABLED=true
ENDSCREEN_DURATION=auto

# ── Feature Flags ──────────────────────────────────────────────────────────
UPLOAD_TO_DRIVE=false
DEBUG=0
